{
  "name": "locusify",
  "type": "module",
  "version": "3.0.6",
  "packageManager": "pnpm@10.15.0",
  "author": "caterpi11ar",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/caterpi11ar/locusify"
  },
  "keywords": [
    "travel",
    "photo",
    "map",
    "route",
    "vlog",
    "geotagging"
  ],
  "scripts": {
    "prepare": "husky install",
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint --fix",
    "typecheck": "tsc -b --noEmit",
    "cap:sync": "cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "build:mobile": "pnpm build && cap sync",
    "build:android": "pnpm build && cap sync android && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.2",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/core": "^8.2.0",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@tanstack/react-query": "^5.90.2",
    "@turf/boolean-point-in-polygon": "^7.3.4",
    "@turf/helpers": "^7.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "es-toolkit": "^1.41.0",
    "exifr": "^7.1.3",
    "lucide-react": "^0.544.0",
    "maplibre-gl": "^5.10.0",
    "mediabunny": "^1.34.4",
    "motion": "^12.23.24",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "^7.64.0",
    "react-i18next": "^15.7.3",
    "react-intersection-observer": "^10.0.0",
    "react-map-gl": "^8.1.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.9.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "thumbhash": "^0.1.1",
    "vaul": "^1.1.2",
    "zod": "^4.1.11",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.2.0",
    "@capacitor/cli": "^8.2.0",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@egoist/tailwindcss-icons": "^1.9.0",
    "@fontsource-variable/inconsolata": "^5.2.8",
    "@iconify-json/mingcute": "^1.2.5",
    "@tailwindcss/vite": "^4.1.13",
    "@types/geojson": "^7946.0.16",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^5.0.0",
    "baseline-browser-mapping": "^2.10.0",
    "exiftool-vendored": "^31.2.0",
    "husky": "^9.1.7",
    "i18next": "^25.5.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "lint-staged": "^16.2.7",
    "react-scan": "^0.4.3",
    "tailwindcss": "^4.1.13",
    "tailwindcss-uikit-colors": "^1.0.0",
    "tw-animate-css": "^1.3.8",
    "typescript": "~5.8.3",
    "vite": "^7.1.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
